# Environment variables for DOU Monitor
# SECURITY: This template is safe to commit.
# NEVER commit .env with real secrets.

# ===================================
# Flask Configuration
# ===================================
DEBUG=True
HOST=127.0.0.1
PORT=5000
FLASK_ENV=development
FLASK_SECRET_KEY=<generate_with: python -c "import secrets; print(secrets.token_urlsafe(32))">

# Session timeout in minutes (default: 30)
# User will be logged out after this period of inactivity
SESSION_TIMEOUT_MINUTES=30

# ===================================
# Authentication
# ===================================
ADMIN_USER=admin
ADMIN_PASS_HASH=<generate_with: python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('YOUR_PASSWORD'))">

# ===================================
# Data Storage (Local Development)
# ===================================
SUMMARIES_DIR=./data/summaries
CONFIG_PATH=./data/dashboard_config.json

# ===================================
# AWS Production (Uncomment for cloud deployment)
# ===================================
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=doumon-summaries
# AWS_PARAMETER_STORE_PREFIX=/doumon/prod
# PLAYWRIGHT_BROWSERS_PATH=/opt/playwright

# ===================================
# Email Configuration (optional)
# ===================================
DOU_EMAIL_FROM=
DOU_EMAIL_TO=
DOU_EMAIL_PASSWORD=
DOU_EMAIL_SMTP_SERVER=smtp.gmail.com
DOU_EMAIL_SMTP_PORT=587

# ===================================
# Webhook Configuration (optional)
# ===================================
DOU_WEBHOOK_URL=

# ===================================
# Monitoring Configuration
# ===================================
DEFAULT_DAYS=7
# LOG_LEVEL=INFO
# SENTRY_DSN=
